# AI 提供商配置（二选一，填哪个用哪个；都填则优先用 DeepSeek）

# DeepSeek API Key（推荐，中文理解更好，国内直连无障碍）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""
NEXT_PUBLIC_DEEPSEEK_API_KEY=""

# Gemini API Key（Google，AI Studio 会自动注入）
# 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
NEXT_PUBLIC_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# 演示现场保险：AI 解析/评估接口失败时返回本地降级结果（设为 1 或 true 开启）
# DEMO_SAFE_MODE="1"
